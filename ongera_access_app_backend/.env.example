# Copy to .env: cp .env.example .env

APP_NAME=Ongera Access App Backend
APP_PORT=8080
APP_ENV=debug

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ongera
DB_SSLMODE=disable

JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_EXPIRY=24h
JWT_ISSUER=ongera-access-app

LOG_LEVEL=info
LOG_FORMAT=text
